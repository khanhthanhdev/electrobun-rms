{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/mainview/*"],
      "@/app/*": ["src/mainview/app/*"],
      "@/features/*": ["src/mainview/features/*"],
      "@/pages/*": ["src/mainview/pages/*"],
      "@/shared/*": ["src/mainview/shared/*"],
      "@/widgets/*": ["src/mainview/widgets/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "build", "../../package/dist"]
}
